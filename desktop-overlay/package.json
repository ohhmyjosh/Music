{
  "name": "joshfy-overlay",
  "version": "1.0.0",
  "private": true,
  "description": "Josh-Fy always-on music visualizer overlay (transparent, driven only by the Josh-Fy web app).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.joshfy.overlay",
    "productName": "Josh-Fy Overlay",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "overlay.html",
      "overlay.js",
      "widget.html",
      "widget.js",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    }
  }
}
